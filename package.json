{
  "name": "artifact-ttl-purge",
  "version": "1.1.0",
  "description": "GitHub Action that deletes workflow artifacts older than a human-readable expiry duration.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,yml,json}\"",
    "format-check": "prettier --check \"**/*.{ts,yml,json}\"",
    "lint": "eslint src",
    "pack": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test-watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "all": "npm run build && npm run format-check && npm run lint && npm run pack && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evansmith1377/artifact-ttl-purge"
  },
  "keywords": [
    "github",
    "action",
    "artifact"
  ],
  "author": "Pavel Kolář",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "parse-duration": "^2.1.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "date-fns": "^4.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.60.0"
  }
}
